# ─── TofuOS Environment Variables ───
# Copy this file to .env.local:  cp .env.example .env.local
# Then fill in your values below. NEVER commit .env.local to git.

# ─── Supabase ───
# Get these from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── AI Provider ───
# Choose: "openai" (default), "google", or "anthropic"
AI_PROVIDER=openai

# Provider API keys (only the active provider needs a key)
OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: override model (provider-specific)
# AI_MODEL=gpt-4o-mini             # OpenAI default
# AI_MODEL=gemini-2.5-flash        # Google default
# AI_MODEL=claude-sonnet-4-5-20250514     # Anthropic default

# ─── Tavily (for Deep Research & Company URL persona generation) ───
# Get your key from: tavily.com
TAVILY_API_KEY=
