# Copy this file to .env.local and fill in your values.
# Do NOT commit .env or .env.local to version control.

# Supabase (Project Settings → API in Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI: OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: model (default: gpt-4o-mini). Use gpt-4o for higher quality.
# OPENAI_MODEL=gpt-4o-mini

# Optional: Tavily for deep research (https://tavily.com)
# TAVILY_API_KEY=tvly-your-tavily-key
