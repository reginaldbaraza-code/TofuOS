# Copy this file to .env.local and fill in your values.
# Do NOT commit .env or .env.local to version control.

# Supabase (Project Settings → API in Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI: Gemini (https://aistudio.google.com/app/apikey)
# Use one of: GOOGLE_GENERATIVE_AI_API_KEY or GEMINI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key
# Optional: model (default: gemini-1.5-flash). On free tier, use gemini-1.5-flash to avoid quota errors.
# GEMINI_MODEL=gemini-1.5-flash
